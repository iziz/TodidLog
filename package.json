{
  "name": "daily-work-log",
  "version": "0.1.0",
  "private": true,
  "description": "A local PWA for timer-based daily work logging.",
  "type": "module",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./styles.css --watch",
    "dev": "npm run build:css && python -m http.server 5173",
    "start": "npm run build:css && python -m http.server 5173"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
