{
  "name": "todidlog",
  "version": "0.1.0",
  "private": true,
  "description": "A local PWA for timer-based work logging.",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:app",
    "build:app": "esbuild ./app.js --bundle --format=esm --outfile=./vendor/app.js --minify",
    "build:css": "tailwindcss -i ./src/styles.css -o ./styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./styles.css --watch",
    "serve": "node ./scripts/server.mjs",
    "dev": "npm run build && npm run serve",
    "start": "npm run build && npm run serve"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@orrery/core": "^0.4.2",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-placeholder": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "dexie": "^4.4.2"
  }
}
